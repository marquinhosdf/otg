Val1[10]       = get_pvar(SPVAR_11,     -99,    99, 0);                Val1[22]        = get_pvar(SPVAR_23,     -99,    99, 0);
Val1[11]       = get_pvar(SPVAR_12,     -99,    99, 0);                Val1[23]        = get_pvar(SPVAR_24,     -99,    99, 0);

// Recoil X                                                 
Val2[0]        = get_pvar(SPVAR_25,     -99,    99, 0);                Val2[12]        = get_pvar(SPVAR_37,     -99,    99, 0);
Val2[1]        = get_pvar(SPVAR_26,     -99,    99, 0);                Val2[13]        = get_pvar(SPVAR_38,     -99,    99, 0);
Val2[2]        = get_pvar(SPVAR_27,     -99,    99, 0);                Val2[14]        = get_pvar(SPVAR_39,     -99,    99, 0);
