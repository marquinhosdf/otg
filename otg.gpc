init {

  for(ModNames_count = 0; ModNames[ModNames_count] != -1; ModNames_count ++) {}
  for(ValNames_count = 0; ValNames[ValNames_count] != -1; ValNames_count ++) {}
  for(WeaponCategory_count = 0; WeaponCategory[WeaponCategory_count] != -1; WeaponCategory_count ++) {}
  for(WeaponName_count = 0; WeaponName[WeaponName_count] != -1; WeaponName_count ++) {}
 
// Recoil Y                                                 
Val1[0]        = get_pvar(SPVAR_1,      -99,    99, 0);                Val1[12]        = get_pvar(SPVAR_13,     -99,    99, 0);
Val1[1]        = get_pvar(SPVAR_2,      -99,    99, 0);                Val1[13]        = get_pvar(SPVAR_14,     -99,    99, 0);
Val1[2]        = get_pvar(SPVAR_3,      -99,    99, 0);                Val1[14]        = get_pvar(SPVAR_15,     -99,    99, 0);
Val1[3]        = get_pvar(SPVAR_4,      -99,    99, 0);                Val1[15]        = get_pvar(SPVAR_16,     -99,    99, 0);
Val1[4]        = get_pvar(SPVAR_5,      -99,    99, 0);                Val1[16]        = get_pvar(SPVAR_17,     -99,    99, 0);
Val1[5]        = get_pvar(SPVAR_6,      -99,    99, 0);                Val1[17]        = get_pvar(SPVAR_18,     -99,    99, 0);
