// Mixed Variables Needed For The Script To Function \\
 
int DisplayTitle = TRUE; // Display Title When The Script Loads, This Needs TO Be TRUE.


int ScreenSaver,BlankScreen,ModMenu,DisplayMenu,ModNameIdx,Toggle,EditMenu,ValNameIdx,WeaponCatIdx,WeaponNameIdx,WepMenu,KillSwitch,SelectedProfileIdx,Profile3,start_idx,end_idx; // Menu Variables \\


