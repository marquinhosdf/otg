Val2[4]        = get_pvar(SPVAR_29,     -99,    99, 0);                Val2[16]        = get_pvar(SPVAR_41,     -99,    99, 0);
Val2[5]        = get_pvar(SPVAR_30,     -99,    99, 0);                Val2[17]        = get_pvar(SPVAR_42,     -99,    99, 0);
Val2[6]        = get_pvar(SPVAR_31,     -99,    99, 0);                Val2[18]        = get_pvar(SPVAR_43,     -99,    99, 0);
Val2[7]        = get_pvar(SPVAR_32,     -99,    99, 0);                Val2[19]        = get_pvar(SPVAR_44,     -99,    99, 0);
Val2[8]        = get_pvar(SPVAR_33,     -99,    99, 0);                Val2[20]        = get_pvar(SPVAR_45,     -99,    99, 0);
Val2[9]        = get_pvar(SPVAR_34,     -99,    99, 0);                Val2[21]        = get_pvar(SPVAR_46,     -99,    99, 0);
Val2[10]       = get_pvar(SPVAR_35,     -99,    99, 0);                Val2[22]        = get_pvar(SPVAR_47,     -99,    99, 0);
Val2[11]       = get_pvar(SPVAR_36,     -99,    99, 0);                Val2[23]        = get_pvar(SPVAR_48,     -99,    99, 0);

}

main {
       ActivateAllButtons(); // Call The Function So That We Can Select Buttons Via Menu, Activate Profiles OR Quick Toggles \\
      /* Enter The Mod Menu */
        if(get_ival(AdsBtn)){  // AdsBtn , This is so that if you play flipped and define your button above you can still enter the menu \\
            if(event_press(PS4_OPTIONS)){
                ModMenu     = TRUE;      // Mod Menu Will Activate \\
                DisplayMenu = TRUE;      // Display The Mod Menu \\ 
                EditMenu    = FALSE;     // Make Sure We Don't Enter Edit Menu when  Entering Mod Menu \\
    
                if(!ModMenu){           // If NOT in the Mod Menu, Display Title \\
                    DisplayTitle = TRUE;
                }
            }
            if(event_press(PS4_SHARE)){
                KillSwitch =! KillSwitch;
                combo_run(KillSwitch)
            }     
            set_val(PS4_OPTIONS,0); set_val(PS4_SHARE,0); // We Block these Buttons from being Activated IN GAME \\
        }
        if(!DisplayTitle){               // If NOT on The Display Title, we are In Mod Menu Instead \\
            if(ModMenu){                  // If we are In Mod Menu \\
                // Menu Navigation Is One Function To Navigate The Menu , 0,2 < <  0 is the minimum Mods Available , 2 is the Maximum Mods Available \\
                ModNameIdx               = ModMenuNavigation(ModNameIdx,0,2);   // ModNameIdx = Variable To Identify So The Script knows Which Menu We Are In \\
                
                Mod1[ProfileIdx]         = ChangeOption(ModNameIdx == 0,Mod1[ProfileIdx],0,WeaponCategory_count);
                set_val(TRACE_1,Mod1[ProfileIdx]);
                Mod2[ProfileIdx]         = ChangeOption(ModNameIdx == 1,Mod2[ProfileIdx],start_idx,end_idx);
                WeaponNameIdx            = Mod2[ProfileIdx]
                
                //Mod2[ProfileIdx]         = ToggleSwitch(ModNameIdx == 1,Mod2[ProfileIdx],0,1); // 0 = Off , 1 = On , \\ OR Example We could Have More Choices Like Below..     
            }
            
            if(EditMenu){   // We are In Edit Menu \\
                // Menu Navigation Is One Function To Navigate The Menu , 0,2 < <  0 is the minimum Editable Values Available , 2 is the Maximum Editble Values Available \\
                ValNameIdx        = MenuNavigation(ValNameIdx,0,1); // ValNameIdx = Variable To Identify So The Script knows Which Menu We Are In \\
                
                Val1[WeaponNameIdx]  = EditValues(ValNameIdx == 0,Val1[WeaponNameIdx]  , -99, 99);  // ProfileIdx , This Means You can have 3 Different Values Per Profile
                set_val(TRACE_1,Val1[WeaponNameIdx])
                Val2[WeaponNameIdx]  = EditValues(ValNameIdx == 1,Val2[WeaponNameIdx]  , -99, 99);
                
                // Limit Values Per Mods , For example AntiRecoil - Vertical - Horizontal , 0 , 1 which is used with the first ModNameIdx == 0
                if(ModNameIdx == 0){
                    ValNameIdx = cycle(ValNameIdx,0,1);
                }
                recoil_y = Val1[WeaponNameIdx]
                set_val(TRACE_2,Val1[WeaponNameIdx])
                   recoil_x = Val2[WeaponNameIdx]
                // Mods Input Here Below QuickToggles \\
                // For Example \\
                
    
                if(isqrt(pow(get_ival(XB1_RX),2) + pow(get_ival(XB1_RY),2)) <= 20) {    // Check if the Square Root of the RIGHT ANALOG STICK is at or below a value of 5
                    if(get_ival(XB1_RT)){    // Check if RT/R2 (RIGHT TRIGGER) is held (Fire trigger for most games)
                        set_val(XB1_RY,recoil_y);    // Set RY to 24
                        set_val(XB1_RX,recoil_x);    // Set RX to 0
                    }
                }
            }
        }
        if(DisplayMenu){ // Display The Menu \\
            cls_oled(OLED_BLACK);  // Clear The OLED Display \\
            rect_oled(0, 0, OLED_WIDTH, OLED_HEIGHT, OLED_BLACK, OLED_WHITE); // Display The Rectangle Around The Text \\
            //line_oled(0, 27, OLED_WIDTH - 1, 27, 1, OLED_WHITE); // Display The Line In Between Text Top/Bottom \\
            led(ProfileIdx); // Different Led Colour Based On Which Profile You Are Using \\
            
            if(EditMenu){  // If EditMenu Display The Editable Mods \\
                printf(center_x(get_valName_chars(ValNameIdx), OLED_FONT_SMALL_WIDTH),7,OLED_FONT_SMALL,OLED_WHITE,ValNames[ValNameIdx]);
                printf(96,22,OLED_FONT_LARGE,OLED_WHITE,MenuText[1]);
                printf(16,25,OLED_FONT_LARGE,OLED_WHITE,MenuText[2]);
            }
            else if(ModMenu){ // If Mod Menu Display Mods
                printf(center_x(get_modName_chars(ModNameIdx), OLED_FONT_SMALL_WIDTH),5,OLED_FONT_SMALL,OLED_WHITE,ModNames[ModNameIdx]); // Display ModNames ( Medium Text )
                // While In Mod Menu Display On/Off Toggles For Mods \\
                if(ModNameIdx == 0){
                    print(center_x(get_WepCatName_chars(Mod1[ProfileIdx]), OLED_FONT_MEDIUM_WIDTH),center_y(OLED_FONT_MEDIUM_HEIGHT),OLED_FONT_MEDIUM,OLED_WHITE,WeaponCategory[Mod1[ProfileIdx]]);
                }
                if(ModNameIdx == 1){
                    print(center_x(get_WepName_chars(WeaponNameIdx), OLED_FONT_MEDIUM_WIDTH),center_y(OLED_FONT_MEDIUM_HEIGHT),OLED_FONT_MEDIUM,OLED_WHITE,WeaponName[WeaponNameIdx]);
                }

            if(ProfileIdx == 0)
                printf(center_x(get_misc_chars(9), OLED_FONT_SMALL_WIDTH),50,OLED_FONT_SMALL,OLED_WHITE,Misc[9]);
               else if(ProfileIdx == 1)
                printf(center_x(get_misc_chars(10), OLED_FONT_SMALL_WIDTH),50,OLED_FONT_SMALL,OLED_WHITE,Misc[10]);
            else if(ProfileIdx == 2)
                printf(center_x(get_misc_chars(11), OLED_FONT_SMALL_WIDTH),50,OLED_FONT_SMALL,OLED_WHITE,Misc[11]);
            }
            Toggle = FALSE;
            DisplayMenu = FALSE;
            
        } // End Of Display Menu \\
        
        if(!ModMenu && !EditMenu) // When NOT In Mod Menu And Edit Menu \\
        {
            if(DisplayTitle)  // We Are Displaying Title \\
            {

                cls_oled(OLED_BLACK);  // Clear OLED Display \\
                rect_oled(0, 0, OLED_WIDTH, OLED_HEIGHT, OLED_BLACK, OLED_WHITE); // Display The Rectangle Around The Text
                led(ProfileIdx); // Different Led Colour Based On Which Profile You Are Using \\
                // Display The Correct Profile ON The Display Title Screen \\
                if(ProfileIdx == 0){
                    printf(center_x(get_misc_chars(9), OLED_FONT_MEDIUM_WIDTH),0,OLED_FONT_MEDIUM,OLED_WHITE,Misc[9]);
                    WeaponNameIdx = Mod2[ProfileIdx]
                    print(center_x(get_WepName_chars(WeaponNameIdx), OLED_FONT_MEDIUM_WIDTH),30,OLED_FONT_MEDIUM,OLED_WHITE,WeaponName[WeaponNameIdx]);
                    }
                   else if(ProfileIdx == 1){
                       WeaponNameIdx = Mod2[ProfileIdx]
                    printf(center_x(get_misc_chars(10), OLED_FONT_MEDIUM_WIDTH),0,OLED_FONT_MEDIUM,OLED_WHITE,Misc[10]);
                    print(center_x(get_WepName_chars(WeaponNameIdx), OLED_FONT_MEDIUM_WIDTH),30,OLED_FONT_MEDIUM,OLED_WHITE,WeaponName[WeaponNameIdx]);
                    }
                else if(ProfileIdx == 2){
                       WeaponNameIdx = Mod2[ProfileIdx]
                    printf(center_x(get_misc_chars(11), OLED_FONT_MEDIUM_WIDTH),0,OLED_FONT_MEDIUM,OLED_WHITE,Misc[11]);
                    print(center_x(get_WepName_chars(WeaponNameIdx), OLED_FONT_MEDIUM_WIDTH),30,OLED_FONT_MEDIUM,OLED_WHITE,WeaponName[WeaponNameIdx]);
                    }
                
                DisplayTitle = FALSE;
                ScreenSaver  = TRUE;
            }
            if(ScreenSaver){  // ScreenSaver, After 10 seconds The Display Will Go Blank , THIS IS TO PREVENT SCREEN BURN \\
                   BlankScreen += get_rtime();
            
                if(BlankScreen >= 10000){
                    cls_oled(OLED_BLACK);
                    BlankScreen = 0;
                    ScreenSaver = TRUE;
                }// End Of BlankScreen \\
            } // End of ScreenSaver \\
            
            if(ProfilesActive){  // If Profiles Are Enabled \\
            
                if(get_val(XB1_Y) && !get_ival(ResyncButton)){
                    if(get_ptime(XB1_Y) > 300){
                        Profile3 = TRUE;
                    }
                    else{
                        Profile3 = FALSE;
                    }
                }
                else if(get_val(ResyncButton)){
                    block(ResyncButton,1000)
                    if(get_ival(XB1_Y)){
                        block(XB1_Y,500);
                        ProfileIdx = 0;
                    }
                    else if(get_ival(XB1_B)){
                        block(XB1_B,500);
                        ProfileIdx = 1;
                    }
                    else if(get_ival(XB1_X)){
                        block(XB1_X,500);
                        ProfileIdx = 2;
                    }
                    if(ModMenu){
                        DisplayMenu = TRUE;
                    }
                    else{
                        DisplayTitle = TRUE;
                    }
                }
                else if(event_release(XB1_Y)){
                    if(Profile3 != TRUE){
                        SelectedProfileIdx =! SelectedProfileIdx;
                        if(ProfileIdx == 0){
                            ProfileIdx = 1;
                        }
                        else{
                            ProfileIdx = 0;
                        }
                    }
                    else if (Profile3){
                        ProfileIdx = 2;
                    }
                    /*else if (Profile3 == FALSE && ProfileIdx == 2){
                        ProfileIdx = 0;
                    }*/
                    if(ModMenu){
                        DisplayMenu = TRUE;
                    }
                    else{
                        DisplayTitle = TRUE;
                    }
                }
               }
                              
        if(!KillSwitch) // If KillSwitch IS NOT Active The Mods Will Be Active \\ 
        {
            // Quick Toggle Activation \\ Change The Variables If You Want QuickToggles \\ 0,1,2 < ModNameIdx Number , Choose Your Buttons At The Top Of The Script \\
            
            Mod1[ProfileIdx]  = Quick_Toggle( ActivateHoldButton[2] , ActivatePressButton[2]  ,Mod1[ProfileIdx],0); // ActivateHoldButton[2] , ActivatePressButton[2] =  ButtonActivation(2,ModNameIdx,6);
            Mod2[ProfileIdx]  = Quick_Toggle( ActivateHoldButton[3] , ActivatePressButton[3]  ,Mod2[ProfileIdx],1); // ActivateHoldButton[3] , ActivatePressButton[3] =  ButtonActivation(3,ModNameIdx,7);
            Mod3[ProfileIdx]  = Quick_Toggle( ActivateHoldButton[4] , ActivatePressButton[4]  ,Mod3[ProfileIdx],2); // ActivateHoldButton[4] , ActivatePressButton[4] =  ButtonActivation(4,ModNameIdx,8);
        
               recoil_y = Val1[WeaponNameIdx]
               recoil_x = Val2[WeaponNameIdx]
            // Mods Input Here Below QuickToggles \\
            // For Example \\
            

            if(isqrt(pow(get_ival(XB1_RX),2) + pow(get_ival(XB1_RY),2)) <= 20) {    // Check if the Square Root of the RIGHT ANALOG STICK is at or below a value of 5
                if(get_ival(XB1_RT)){    // Check if RT/R2 (RIGHT TRIGGER) is held (Fire trigger for most games)
                    set_val(XB1_RY,recoil_y);    // Set RY to 24
                    set_val(XB1_RX,recoil_x);    // Set RX to 0
                }
            }
            if (get_ival(XB1_RT)) {    // Check if RT/R2 is held
                combo_run(RAPID_FIRE); // Run Rapid Fire combo while RT/R2 is held
            }
            /*
            if(AntiRecoil)
            {
                if(get_ival(FireBtn)
                {
                    combo_run(LegacyRecoil)
                }
            }
            */       
        } // End Of Mods \\ 
       }
}// End Of Script \\
    
// Menu Navigation Function For BOTH Menu's \\
function ModMenuNavigation(f_modorval,f_min,f_max) {

    if(!get_val(AdsBtn)){
        if(event_press(PS4_UP)){   // Press Right To See Next Mod/Value 
            f_modorval = cycle(f_modorval + 1, f_min , f_max  );
            DisplayMenu = TRUE;   
           }     
        if(event_press(PS4_DOWN)){    // Press Left To See Next Mod/Value
            f_modorval = cycle(f_modorval - 1, f_min , f_max  );
            DisplayMenu = TRUE;
        }
        set_val(PS4_UP,0); set_val(PS4_DOWN,0); 
    }
    if(f_modorval == 0){  // If in Armory MOD (Displaying Weapon Categories)
        if(event_press(PS4_CROSS)){  // Enter Edit Menu  \\
            f_modorval   = 1
            ModMenu      = TRUE;
            DisplayMenu  = TRUE;
            start_idx    = WepToCat[Mod1[ProfileIdx]][0]
            end_idx      = WepToCat[Mod1[ProfileIdx]][1]
            Mod2[ProfileIdx] = start_idx
        }
        set_val(PS4_CROSS,0);
        
        if(event_press(PS4_CIRCLE)){  // Press Circle To Exit The Menu && Display The Title Screen \\
            DisplayTitle = TRUE;
            ModMenu      = FALSE;
            DisplayMenu  = FALSE;
            combo_run(RumbleOff);
        }
        set_val(PS4_CIRCLE,0);
        
    }
    else if(f_modorval == 1){  // If in Select Weapon MOD (Displaying Weapon Names)
        if(event_press(PS4_CROSS)){  // Enter Edit Menu  \\
            f_modorval  = 2;
            EditMenu    = TRUE;
            ModMenu     = FALSE;
            DisplayMenu = TRUE;
            ValNameIdx  = 0;
        }
        set_val(PS4_CROSS,0);
        if(event_press(PS4_CIRCLE)){  // Press Circle To Exit The Menu && Display The Title Screen \\
            f_modorval = 0;
            ModMenu     = FALSE;
            DisplayMenu  = TRUE;
            DisplayTitle = TRUE;
            combo_run(RumbleOff);
        }
        set_val(PS4_CIRCLE,0);
    }
    return f_modorval
}
function MenuNavigation(f_modorval,f_min,f_max) {

    // Change From Recoil Y to Recoil X by press up or down
    
    if(!get_val(AdsBtn)){
        if(event_press(PS4_UP)){   // Press Right To See Next Mod/Value
            f_modorval = cycle(f_modorval + 1, f_min , f_max  );
            DisplayMenu = TRUE;   
           }     
        if(event_press(PS4_DOWN)){    // Press Left To See Next Mod/Value
            f_modorval = cycle(f_modorval - 1, f_min , f_max  );
            DisplayMenu = TRUE;
        }
        set_val(PS4_UP,0); set_val(PS4_DOWN,0); 
    }

    if(f_modorval == 2){  // If in Recoil Mod
        if(event_press(PS4_CROSS)){  // Enter Edit Menu  \\
            ValNameIdx  = 0; // Total Amount Of Values Available In Edit Menu \\
            EditMenu    = TRUE;
            ModMenu     = FALSE;
            DisplayMenu = TRUE;
        }
        set_val(PS4_CROSS,0);
    }
    if(ModMenu){  // When In Mod Menu  \\
        if(event_press(PS4_CIRCLE)){  // Press Circle To Exit The Menu && Display The Title Screen \\
            DisplayTitle = TRUE;
            ModMenu      = FALSE;
            DisplayMenu  = FALSE;
            combo_run(RumbleOff);
        }
        set_val(PS4_CIRCLE,0);
    }
    if(EditMenu){ // When In Edit Menu \\
        if(event_press(PS4_CIRCLE)){  // Press Circle To Exit The Edit Menu && Display The Mod Menu \\
            EditMenu     = FALSE;
               ModMenu      = TRUE;
            DisplayMenu  = TRUE;
            //ValNameIdx   = 0;
            ModNameIdx   = 1;
            //save_vals(WeaponNameIdx)
        }
        set_val(PS4_CIRCLE,0);
    }
    if(event_press(PS4_TRIANGLE)){
        ProfileIdx = cycle(ProfileIdx + 1, 0, TotalNumberOfProfiles);
        DisplayMenu = TRUE;       
    }
    return f_modorval;
}
