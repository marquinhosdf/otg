//int Val1[] = {43, 0, 47, 44, 46, 46, 47, 54, 52, 52, 55, 57, 57, 60, 47, 44, 50, 47, 49, 7, 61, 50, 0}
//int Val2[] = {-5, 0, -3, -6, -5, -5, -4, -6, -7, -8, -2, -4, -5, 6, 0, -2, -2, -1, -3, 0, -2, -2, 0}

int a;
int b;


int mem_start_val1 = -32768;
int mem_start_val2 = -32744;

int mem_slot_v1;
int mem_slot_v2;

